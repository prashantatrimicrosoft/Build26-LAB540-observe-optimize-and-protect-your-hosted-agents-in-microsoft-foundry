# build26-repo-template

Template files will not be tracked by git.
*.bak
*.tmp

# Source materials folder — contents excluded, README tracked
_remove-before-publish/*
!_remove-before-publish/README.md

# OS files
.DS_Store
Thumbs.db

# IDE files (except .vscode/mcp.json which we want)
.idea/
*.swp
*.swo

# Environment files with secrets
.env
.env.local
.env.*.local

# Dependencies (if applicable)
node_modules/
__pycache__/
*.pyc
.venv/

# Do not commit (staging only)
.do_not_commit/

# Per-learner workshop state (regenerated from template each run)
workshop/progress.json

# Per-learner Foundry workspace state (eval results regenerated every run)
# Keep tracked: agent-metadata.yaml, datasets/, evaluators/ (workshop seed assets)
**/.foundry/results/

# Per-learner scoreboard files (contain project IDs, eval IDs, portal URLs)
# Keep tracked: README.md, template.md (workshop authored)
workshop/scoreboard/*.md
!workshop/scoreboard/README.md
!workshop/scoreboard/template.md
