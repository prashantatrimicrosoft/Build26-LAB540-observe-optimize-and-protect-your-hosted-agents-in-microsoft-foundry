# =======================================================================
#  LAB540 — Environment configuration template
# =======================================================================
#  QUICK START (recommended):
#    Run the discovery script from the repo root — it auto-detects your
#    Azure resources (including the azd env, if you used `azd up`) and
#    populates .env for you:
#
#      chmod +x scripts/discover-env.sh
#      ./scripts/discover-env.sh
#
#  MANUAL SETUP:
#    1. Copy this file to .env at the repo root:
#         cp scripts/sample.env .env
#    2. Fill in the values below (see workshop/docs/00-setup/ for where
#       to find each value in the Foundry portal)
#
#  The .env file is git-ignored and will NOT be committed.
# ============================================================


# ----------------------------------------------------------
#  AZURE_SUBSCRIPTION_ID  (Required)
# ----------------------------------------------------------
#  Your Azure subscription ID.
#  FIND IT: az account show --query id -o tsv
# ----------------------------------------------------------
AZURE_SUBSCRIPTION_ID=


# ----------------------------------------------------------
#  AZURE_RESOURCE_GROUP  (Required)
# ----------------------------------------------------------
#  Resource group containing your Foundry project and ACR.
#  FIND IT: Azure Portal → Resource Groups
# ----------------------------------------------------------
AZURE_RESOURCE_GROUP=


# ----------------------------------------------------------
#  AZURE_LOCATION  (Required — Self-Guided provisioning)
# ----------------------------------------------------------
#  Azure region where `azd up` will provision the Foundry project,
#  model deployment, ACR, and monitoring resources.
#
#  Only three regions are supported for this workshop — all three are
#  in the Foundry Hosted Agents preview region list with gpt-4.1-mini
#  quota:
#
#    • eastus2         ← default (broadest tool support, primary US region)
#    • swedencentral   ← EU alternate (best for European learners)
#    • northcentralus  ← US backup (use if eastus2 quota is exhausted)
#
#  Skillable lab attendees: this value is auto-populated from the
#  pre-provisioned resource group — leave as-is.
# ----------------------------------------------------------
AZURE_LOCATION=eastus2


# ----------------------------------------------------------
#  AZURE_AI_PROJECT_ENDPOINT  (Required — All Modules)
# ----------------------------------------------------------
#  Full project endpoint URL for your Foundry project.
#  FORMAT: https://<account>.services.ai.azure.com/api/projects/<project>
#  FIND IT: Foundry Portal → Your Project → Overview → Project endpoint
# ----------------------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=


# ----------------------------------------------------------
#  AZURE_AI_MODEL_DEPLOYMENT_NAME  (Required — All Modules)
# ----------------------------------------------------------
#  Name of the deployed chat model your agent will use.
#  DEFAULT: gpt-4.1-mini  (matches what `azd up` provisions via zava/azure.yaml).
#  ⚠️  This MUST match the exact deployment name shown in Foundry Portal → Models + endpoints.
#      If you deployed a different model, change this value to match.
#  FIND IT: Foundry Portal → Models + endpoints → Name column
# ----------------------------------------------------------
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini


# ----------------------------------------------------------
#  AZURE_CONTAINER_REGISTRY_NAME  (Required — Deployment)
# ----------------------------------------------------------
#  Name of the Azure Container Registry for agent images.
#  Must be in the same resource group as the Foundry project.
#  FIND IT: Azure Portal → Container Registries → Name
# ----------------------------------------------------------
AZURE_CONTAINER_REGISTRY_NAME=


# ----------------------------------------------------------
#  AZURE_CONTAINER_REGISTRY_LOGIN_SERVER  (Required — Deployment)
# ----------------------------------------------------------
#  Login server FQDN of the ACR (e.g. <name>.azurecr.io).
#  Used by `docker tag` / `docker push` when redeploying.
#  Auto-discovered by scripts/discover-env.sh from the ACR name.
# ----------------------------------------------------------
AZURE_CONTAINER_REGISTRY_LOGIN_SERVER=


# ----------------------------------------------------------
#  APPLICATIONINSIGHTS_CONNECTION_STRING  (Optional — Tracing / Lab 4)
# ----------------------------------------------------------
#  Application Insights connection string for tracing/telemetry.
#  Required for trace analysis in Lab 4.
#  This is the canonical OpenTelemetry env var name — the Azure SDK
#  and OTel auto-instrumentation read it directly.
#  FIND IT: Azure Portal → Application Insights → Overview → Connection String
#  Auto-discovered by scripts/discover-env.sh.
# ----------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=


# ----------------------------------------------------------
#  FOUNDRY_PORTAL_URL  (Convenience — auto-derived)
# ----------------------------------------------------------
#  Direct link to your Foundry project in https://ai.azure.com.
#  Auto-derived by scripts/discover-env.sh from the project endpoint
#  + subscription + resource group. Open it to find your agent,
#  model deployments, traces, and evaluations.
# ----------------------------------------------------------
FOUNDRY_PORTAL_URL=


# ----------------------------------------------------------
#  AZURE_PORTAL_RG_URL  (Convenience — auto-derived)
# ----------------------------------------------------------
#  Direct link to your resource group in the Azure portal.
#  Auto-derived by scripts/discover-env.sh.
# ----------------------------------------------------------
AZURE_PORTAL_RG_URL=


# ----------------------------------------------------------
#  AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED  (Recommended)
# ----------------------------------------------------------
#  When true, the Azure SDK records full prompt/completion content
#  in traces — useful for the evaluation modules.
# ----------------------------------------------------------
AZURE_TRACING_GEN_AI_CONTENT_RECORDING_ENABLED=true


# ----------------------------------------------------------
#  AZURE_LOG_LEVEL  (Optional)
# ----------------------------------------------------------
#  Reduces logging verbosity for Azure SDKs.
#  Set to "error" to suppress informational messages.
# ----------------------------------------------------------
AZURE_LOG_LEVEL=error